<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8"
    android:padding="24dp"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Gerar QR Code"
            android:textColor="#009688"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editTextNomeEvento"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:hint="Nome do evento"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="#000000"
            android:textColorHint="#2F2B2B" />

        <EditText
            android:id="@+id/editTextDataHoraInicio"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:digits="0123456789/+:"
            android:hint="Data e hora de início (dd/mm/aaaa+hh:mm)"
            android:inputType="datetime"
            android:maxLength="16"
            android:padding="12dp"
            android:textColor="#000000"
            android:textColorHint="#2F2B2B" />

        <EditText
            android:id="@+id/editTextDataHoraTermino"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:digits="0123456789/+:"
            android:hint="Data e hora de término (dd/mm/aaaa+hh:mm)"
            android:inputType="datetime"
            android:maxLength="16"
            android:padding="12dp"
            android:textColor="#000000"
            android:textColorHint="#2F2B2B" />

        <EditText
            android:id="@+id/editTextEndereco"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:hint="Endereço"
            android:inputType="textPostalAddress"
            android:padding="12dp"
            android:textColor="#000000"
            android:textColorHint="#2F2B2B" />

        <EditText
            android:id="@+id/editTextDescricao"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginBottom="16dp"
            android:gravity="top"
            android:hint="Descrição"
            android:inputType="textMultiLine"
            android:padding="12dp"
            android:textColor="#000000"
            android:textColorHint="#2F2B2B" />

        <Button
            android:id="@+id/buttonGenerate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GERAR QR CODE"
            android:backgroundTint="#0066FF"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <ImageView
            android:id="@+id/imageViewQRCode"
            android:layout_width="250dp"
            android:layout_height="259dp"
            android:layout_gravity="center"
            android:contentDescription="QR Code" />

        <!-- Botões corrigidos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btnSalvar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="#009688"
                android:text="Salvar"
                android:textColor="#F0F0F0" />

            <Button
                android:id="@+id/btnVoltar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#009688"
                android:text="Voltar"
                android:textColor="#F8F5F5" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
